local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Pastikan folder Remotes ada
local Remotes = ReplicatedStorage:FindFirstChild("Remotes")
if not Remotes then
    Remotes = Instance.new("Folder")
    Remotes.Name   = "Remotes"
    Remotes.Parent = ReplicatedStorage
end

local function ensureRemote(name: string)
    local existing = Remotes:FindFirstChild(name)
    if existing then return existing end
    local re = Instance.new("RemoteEvent")
    re.Name   = name
    re.Parent = Remotes
    return re
end

-- Task system
ensureRemote("TaskProgress")   -- serverâ†’all: counter update
ensureRemote("TaskInteract")   -- clientâ†’server: player complete task
ensureRemote("GameWin")        -- serverâ†’all: win event
ensureRemote("SyncState")      -- serverâ†’client: late-join sync

-- Survival system
ensureRemote("HungerUpdate")   -- serverâ†’client: hunger value
ensureRemote("DarkUpdate")     -- serverâ†’client: dark timer + inDark
ensureRemote("PlayerDied")     -- serverâ†’all: (name, cause)
ensureRemote("EatFood")        -- clientâ†’server: food pickup

-- Monster / Sensor system
ensureRemote("MonsterPosition")   -- serverâ†’all: monster pos + state
ensureRemote("PlayerMakeNoise")   -- clientâ†’server: player made noise
ensureRemote("AwarenessUpdated")   -- serverâ†’client: awareness level per player
ensureRemote("RulesActivated")     -- serverâ†’all: active rules list
ensureRemote("MapGenerated")        -- serverâ†’all: map grid data
ensureRemote("ReviveRequest")      -- clientâ†’server: request revive
ensureRemote("PlayerRevived")      -- serverâ†’all: player revived
ensureRemote("ConveyorStateChanged")-- serverâ†’all: conveyor on/off
ensureRemote("SurvivalUpdated")     -- serverâ†’client: survival state
ensureRemote("PlayerInteractTask")  -- clientâ†’server: interact with task
ensureRemote("TaskProgressUpdated") -- serverâ†’client: task progress
ensureRemote("LevelProgressSaved")  -- serverâ†’client: level progress
ensureRemote("GameOver")            -- serverâ†’all: game over
ensureRemote("LevelCleared")       -- serverâ†’all: level cleared
ensureRemote("TeleportDataReceived")-- serverâ†’client: teleport data

print("[RemoteSetup] Semua RemoteEvent sudah siap di ReplicatedStorage.Remotes")
